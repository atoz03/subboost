{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"],
      "@local/*": ["./src/*"],
      "@subboost/core": ["../packages/core/src/index.ts"],
      "@subboost/core/*": ["../packages/core/src/*"],
      "@subboost/server-core": ["../packages/server-core/src/index.ts"],
      "@subboost/server-core/*": ["../packages/server-core/src/*"],
      "@subboost/ui": ["../packages/ui/src/index.ts"],
      "@subboost/ui/*": ["../packages/ui/src/*"],
      "@subboost/config/*": ["../packages/config/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules"]
}
